@using System.Globalization
@model List<razor_pages.Models.Product>

<div class="best-sellers-widget mt-4 p-4 bg-light border rounded shadow-sm">
    <h3 class="text-danger">Best-selling products</h3>
    <hr />
    <ul class="list-group">
        @foreach (var product in Model)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-0 fw-bold">@product.Name</h6>
                    <small class="text-muted">Sold: <strong>@product.SoldQuantity</strong></small>
                </div>
                <span class="fs-6">
                    @product.Price.ToString("C", CultureInfo.CreateSpecificCulture("vi-VN"))
                </span>
            </li>
        }
    </ul>
</div>