@model MyApp.Namespace.Models.Student

<div class="detail-card mt-4 p-4 border rounded shadow-sm bg-white">
    <h3 class="text-primary">Student Details</h3>
    <hr />
    <p><strong>ID:</strong> @Model.Id</p>
    <p><strong>Name:</strong> @Model.Name</p>
    <p><strong>Age:</strong> @Model.Age</p>
    <p><strong>Major:</strong> @Model.Major</p>
</div>