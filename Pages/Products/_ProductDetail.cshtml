@using System.Globalization
@model MyApp.Namespace.Models.Product

<div class="detail-card mt-4 p-4 border rounded shadow-sm bg-white">
    <h3 class="text-success">Product Details</h3>
    <hr />
    <p><strong>ID:</strong> @Model.Id</p>
    <p><strong>Product Name:</strong> @Model.Name</p>
    <p><strong>Price:</strong> @Model.Price.ToString("C", CultureInfo.CreateSpecificCulture("vi-VN"))</p>
    <p><strong>Description:</strong> @Model.Description</p>
</div>