@page
@model razor_pages.Pages.Products.IndexModel

@{
    ViewData["Title"] = "Product";
}

<h1 class="mb-4">Product Management</h1>

<form method="get" class="mb-4">
    <div class="input-group">
        <input type="text" asp-for="SearchKeyWord" class="form-control" placeholder="Please enter keyword ...">
            <button type="submit" class="btn btn-dark">Search</button>
        </div>
    </form>

    <div class="mb-3">
        <a asp-page-handler="LoadAll" class="btn btn-success">Load All Products</a>
        <a asp-page-handler="RemoveAll" class="btn btn-danger">Remove All Products</a>
    </div>

    <h3 class="mb-3">List Products</h3>
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Product Id</th>
                <th>Product Name</th>
                <th>Category</th>
                <th>Price</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Products != null && Model.Products.Count > 0)
            {
                foreach (var product in Model.Products)
                {
                    <tr>
                        <td>@product.Id</td>
                        <td>@product.Name</td>
                        <td>@product.Category</td>
                        <td class="text-success fw-bold">@product.Price.ToString("N0") VNĐ</td>
                        <td class="text-center">
                            <a asp-page="./Index" asp-route-id="@product.Id" class="btn btn-sm btn-primary">View Details</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6">No products!</td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.SelectedProduct != null)
    {
        <div class="card bg-light mb-4">
            <div class="card-body">
                <h4>Product Details</h4>
                <p><strong>ID:</strong> @Model.SelectedProduct.Id</p>
                <p><strong>Name:</strong> @Model.SelectedProduct.Name</p>
                <p><strong>Price:</strong> @Model.SelectedProduct.Price.ToString("N0") VNĐ</p>
                <p><strong>Description:</strong> @Model.SelectedProduct.Description</p>
            </div>
        </div>
    }

    <div class="form-group">
        <h3>Create Product</h3>
        <form method="post" class="mt-3" asp-page-handler="Create">
            <div class="form-group mb-2">
                <label>Product Name:</label>
                <input type="text" asp-for="InputProduct.Name" class="form-control w-25 border-dark" required />
            </div>
            <div class="form-group mb-2">
                <label>Product Price:</label>
                <input type="number" asp-for="InputProduct.Price" class="form-control w-25 border-dark" required />
            </div>
            <div class="input-group mb-3">
                <div class="input-group-prepend">
                    <label class="input-group-text" for="inputGroupSelect01">Category</label>
                </div>
                <select asp-for="InputProduct.Category" class="custom-select w-auto rounded" id="inputGroupSelect01">
                    <option selected>Choose...</option>
                    <option value="1">Accessory</option>
                    <option value="2">Laptop</option>
                    <option value="3">Phone</option>
                </select>
            </div>
            <div class="form-group mb-2">
                <label>Product Description:</label>
                <textarea asp-for="InputProduct.Description" class="form-control w-25 border-dark" rows="4"></textarea>
            </div>
            <button type="submit" class="btn btn-dark">Create</button>
        </form>
    </div>
   



