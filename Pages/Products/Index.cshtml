@page "{id:int?}"
@model razor_pages.Pages.Products.IndexModel
@{
    ViewData["Title"] = "List Product";
}

<h2>List Product (Partial Views)</h2>

<table class="product-table table table-bordered">
    <thead class="table-success">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Price</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model.Products)
        {
            <tr>
                <td>@product.Id</td>
                <td>@product.Name</td>
                <td>@product.Price</td>
                <td>@product.Description</td>
                <td>
                    <a asp-page="/Products/Details" asp-route-id="@product.Id" class="btn btn-sm btn-primary">
                        View Detail
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.SelectedProduct != null)
{
    <partial name="_ProductDetail" model="Model.SelectedProduct" />
}

@* <vc:product-list></vc:product-list> *@
@* <vc:product-list sort-order="asc"></vc:product-list> *@
@* <vc:product-list sort-order="desc"></vc:product-list> *@
@* <vc:best-sellers></vc:best-sellers> *@

@* @await Component.InvokeAsync("ProductList") *@
@await Component.InvokeAsync("ProductList", new { sortOrder = "asc", quantity = 5 })
@* @await Component.InvokeAsync("ProductList", new { sortOrder = "desc" }) *@
@await Component.InvokeAsync("ProductList", new { sortAsc = false, quantity = 5 })
@await Component.InvokeAsync("BestSellers")
@await Component.InvokeAsync("ProductByCategory", new { category = "Electronics" })
@await Component.InvokeAsync("ProductByCategory", new { category = "Books" })
